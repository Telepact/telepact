{
  "name": "telepact-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Full-stack Telepact todo demo",
  "scripts": {
    "build": "npm run build:frontend && npm run build:bff",
    "build:frontend": "vite build --config apps/frontend/vite.config.ts",
    "build:bff": "tsc -p apps/bff/tsconfig.json",
    "dev:frontend": "vite --config apps/frontend/vite.config.ts",
    "dev:bff": "tsx watch apps/bff/src/server.ts",
    "start:bff": "node apps/bff/dist/server.js",
    "test:frontend": "vitest run --config apps/frontend/vitest.config.ts",
    "test:bff": "vitest run --config apps/bff/vitest.config.ts",
    "test:e2e": "./scripts/test-e2e.sh"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "telepact": "1.0.0-alpha.204"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
